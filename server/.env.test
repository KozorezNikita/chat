# ============================================
# TEST environment
# ============================================
# Окремий Postgres на порту 5433 (з docker-compose.test.yml).
# Запусти його перед тестами:
#   docker compose -f docker-compose.test.yml up -d
# ============================================

NODE_ENV=test
PORT=5001
LOG_LEVEL=silent
CORS_ORIGIN=http://localhost:3000

DATABASE_URL="postgresql://test:test@localhost:5433/test_db"
REDIS_URL="redis://localhost:6379"

# Тестові секрети — НЕ використовувати у проді.
JWT_ACCESS_SECRET="test_access_secret_at_least_32_chars_long_xx"
JWT_REFRESH_SECRET="test_refresh_secret_at_least_32_chars_long_x"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_DOMAIN=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Test <test@chat.local>"

CLIENT_URL=http://localhost:3000
