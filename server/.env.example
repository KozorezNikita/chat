# ============================================
# Server environment
# ============================================
#
# DEVELOPMENT — копіюй у .env, запускай docker-compose up.
# PRODUCTION (Render) — налаштуй у Render Dashboard → Environment.

# ============================================
# Application
# ============================================

# development | production
NODE_ENV=development

# Render автоматично виставляє PORT — не пере-визначай у prod
PORT=5000

# fatal | error | warn | info | debug | trace | silent
# Prod: info. Dev: debug.
LOG_LEVEL=debug

# Origin фронтенду — для CORS і Socket.io
# Dev: http://localhost:3000
# Prod: https://chat-yourname.vercel.app  (без trailing slash)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Database
# ============================================

# Dev: docker postgres
# Prod: Neon connection string з ?sslmode=require
DATABASE_URL="postgresql://chatapp:chatapp_dev_password@localhost:5432/chat"

# Опційний. Якщо встановлено — Socket.io використовує Redis adapter
# (потрібно лише при multi-instance scaling).
# Dev: не потрібен (закоментуй).
# Prod single instance: не потрібен (закоментуй).
# Prod 2+ instances: Upstash Redis URL (rediss:// з паролем).
# REDIS_URL="redis://localhost:6379"

# ============================================
# JWT
# ============================================

# Згенеруй кожен окремо: openssl rand -base64 48
# У prod ОБОВ'ЯЗКОВО різні від dev і між собою.
JWT_ACCESS_SECRET="change-me-to-strong-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-to-different-strong-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Cookies
# ============================================

# Опційний. Якщо хочеш cookies на subdomains — встанови ".your-domain.com"
# Дефолт (порожньо): cookies лише на поточному origin.
# У нашому prod setup (Vercel + Render — різні домени) лишай порожнім,
# cookies працюватимуть через sameSite=none + secure.
COOKIE_DOMAIN=# ============================================
# Server environment
# ============================================
#
# DEVELOPMENT — копіюй у .env, запускай docker-compose up.
# PRODUCTION (Render) — налаштуй у Render Dashboard → Environment.

# ============================================
# Application
# ============================================

# development | production
NODE_ENV=development

# Render автоматично виставляє PORT — не пере-визначай у prod
PORT=5000

# fatal | error | warn | info | debug | trace | silent
# Prod: info. Dev: debug.
LOG_LEVEL=debug

# Origin фронтенду — для CORS і Socket.io
# Dev: http://localhost:3000
# Prod: https://chat-yourname.vercel.app  (без trailing slash)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Database
# ============================================

# Dev: docker postgres
# Prod: Neon connection string з ?sslmode=require
DATABASE_URL="postgresql://chatapp:chatapp_dev_password@localhost:5432/chat"

# Опційний. Якщо встановлено — Socket.io використовує Redis adapter
# (потрібно лише при multi-instance scaling).
# Dev: не потрібен (закоментуй).
# Prod single instance: не потрібен (закоментуй).
# Prod 2+ instances: Upstash Redis URL (rediss:// з паролем).
# REDIS_URL="redis://localhost:6379"

# ============================================
# JWT
# ============================================

# Згенеруй кожен окремо: openssl rand -base64 48
# У prod ОБОВ'ЯЗКОВО різні від dev і між собою.
JWT_ACCESS_SECRET="change-me-to-strong-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-to-different-strong-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Cookies
# ============================================

# Опційний. Якщо хочеш cookies на subdomains — встанови ".your-domain.com"
# Дефолт (порожньо): cookies лише на поточному origin.
# У нашому prod setup (Vercel + Render — різні домени) лишай порожнім,
# cookies працюватимуть через sameSite=none + secure.
COOKIE_DOMAIN=

# ============================================
# SMTP
# ============================================

# Dev: Mailpit з docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Chat App <noreply@chat.local>"

# Prod options:
#   - Resend.com — https://resend.com (3000 emails/місяць безкоштовно)
#       SMTP_HOST=smtp.resend.com SMTP_PORT=587 SMTP_USER=resend SMTP_PASS=re_xxx
#   - SendGrid free tier
#   - AWS SES

# ============================================
# Frontend URL — для посилань у листах
# ============================================

# Dev: http://localhost:3000
# Prod: https://chat-yourname.vercel.app
CLIENT_URL=http://localhost:3000

# ============================================
# S3 storage (file uploads) — Iter 7
# ============================================
#
# Dev: MinIO у docker-compose. Console: http://localhost:9001
# Prod: Cloudflare R2 (https://dash.cloudflare.com/?to=/:account/r2)
#
# Не задано — upload endpoint поверне 503. Зручно для тестів.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=chat-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin


# ============================================
# SMTP
# ============================================

# Dev: Mailpit з docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Chat App <noreply@chat.local>"

# Prod options:
#   - Resend.com — https://resend.com (3000 emails/місяць безкоштовно)
#       SMTP_HOST=smtp.resend.com SMTP_PORT=587 SMTP_USER=resend SMTP_PASS=re_xxx
#   - SendGrid free tier
#   - AWS SES

# ============================================
# Frontend URL — для посилань у листах
# ============================================

# Dev: http://localhost:3000
# Prod: https://chat-yourname.vercel.app
CLIENT_URL=http://localhost:3000
