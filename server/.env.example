# ============================================
# Server environment
# ============================================

# Application
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:lacazette10!@localhost:5432/chat"

# Redis (для presence у Ітерації 4 і socket.io adapter)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-to-strong-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-to-different-strong-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookie domain — у dev порожній
COOKIE_DOMAIN=

# SMTP (Mailpit у dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Chat App <noreply@chat.local>"

# URL фронтенду — для посилань у листах
CLIENT_URL=http://localhost:3000
