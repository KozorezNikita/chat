# ============================================
# Root-level env — використовується docker-compose
# Сервісні .env живуть у server/.env та client/.env.local
# ============================================

# Postgres (dev)
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp_dev_password
POSTGRES_DB=chatapp
POSTGRES_PORT=5432

# Redis (dev)
REDIS_PORT=6379

# Mailpit (dev SMTP server + Web UI)
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
